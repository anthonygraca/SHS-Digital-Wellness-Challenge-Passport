# Template. Copy to .deploy-local/env and fill in, then `source` it before running
# anything in scripts/deploy/ (see docs/deploy.md).
#
# This file is the ONE thing under .deploy-local/ that is committed; the .gitignore
# rule keeps every other path here — including the filled-in env — out of the repo,
# because the repo is public and these are real identifiers.
#
# You only need this if you are adopting a deployment someone else provisioned.
# Standing one up from scratch? Run scripts/deploy/provision.sh instead — it
# creates the infrastructure and writes .deploy-local/env for you. Do not run it
# to join an existing deployment: it would create a second instance and a second
# Elastic IP rather than pointing at the first.

# Required by lib.sh; every script fails fast without these.
export AWS_REGION=us-west-2
export AWS_ACCOUNT_ID=
export INSTANCE_ID=

# Derived from the account id + region by lib.sh, but harmless to set explicitly.
export ECR_REPO=

# Required by access.sh and status.sh.
export SECURITY_GROUP_ID=

# The Elastic IP. ALLOCATION_ID is what up.sh re-associates after a stop/start and
# what destroy.sh releases; APP_HOST is that address, and is what lib.sh uses as
# the app's URL rather than asking EC2 for whatever IP is currently attached.
export ALLOCATION_ID=
export APP_HOST=

# Recorded by provision.sh for reference. Not read by any script: the running
# deployment gets these through EC2 user-data at provision time. Left blank here
# means the app falls back to the dev defaults committed in backend/app/config.py,
# which are forgeable by anyone with the repo.
export WP_JWT_SECRET=
export WP_QR_SECRET=
