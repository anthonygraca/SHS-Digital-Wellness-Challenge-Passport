# Keep the build context small and the image clean. Anything not needed to build
# the SPA or run the API stays out.

.git
.github
docs
scripts
.claude

# Python
backend/.venv
backend/**/__pycache__
backend/**/*.pyc
backend/.pytest_cache
backend/.ruff_cache
backend/**/*.egg-info
backend/tests

# The local dev database. Never bake developer data into an image — the runtime
# reads its DB from the /data volume instead.
backend/*.db

# Secrets. There is no .env in the repo today; this makes sure one never rides
# into an image if someone adds it locally.
**/.env

# Node: npm ci rebuilds these from the lockfile inside the image, and a host
# node_modules would be both huge and possibly wrong-platform.
frontend/node_modules
frontend/dist
frontend/coverage
frontend/**/*.tsbuildinfo

**/.DS_Store
